# https://github.com/bazel-contrib/rules_foreign_cc/blob/main/docs/README.md#cmake
cmake(
    name = "sdl3_cmake_base",
    lib_source = ":all_srcs",
    data = [":CmakePreseedCache"],
    env = {
        "PRESEED_CACHE": "$(execpath :CmakePreseedCache)",

        #TODO: determine optimal value for parallel build
        "CMAKE_BUILD_PARALLEL_LEVEL": "8", 
    },
    generate_args = [
        "-DSDL_STATIC=true",
        "-DSDL_SHARED=false",
        "-DSDL_PTHREADS=true",

        "-DSDL_TEST_LIBRARY=OFF",  #TODO: config_setting with default ON, and disable only for Android where it fails to link now

        "-DCMAKE_PROJECT_INCLUDE=$PRESEED_CACHE",
    ] + select({
        "@platforms//os:android": ["-DSDL_TEST_LIBRARY=OFF"],  # test libcheckkeys.so fails to link on Android now
        "@platforms//cpu:wasm32": ["-DEMSCRIPTEN=true"],
        "@platforms//os:wasi": ["-DEMSCRIPTEN=true"],
        "@bazel_tools//src/conditions:darwin": [
            "-DCMAKE_PREFIX_PATH=/opt/homebrew",
        ],
        "//conditions:default": []
    }),
    defines = select({
        "@bazel_tools//src/conditions:darwin": [
            "CMAKE_OSX_DEPLOYMENT_TARGET=10.13",
        ],
        "//conditions:default": []
    }),
    out_include_dir = "include",
    out_static_libs = select({
        "@bazel_tools//src/conditions:windows": ["SDL3-static.lib"],
        "//conditions:default": ["libSDL3.a"],
    }),
    visibility = ["//visibility:private"],
)

# linkopts in cmake rule w/ space isn't passed to dependents correctly, so declare wrapped cc_library to pass them
cc_library(
    name = "sdl3_cmake_cc",
    deps = [":sdl3_cmake_base"],

    # includes/strip_include_prefix only for hedron_compile_commands to generate correct value for SDL3/SDL.h, etc
    #   cmake rule generates them correctly, but they aren't passed there
    strip_include_prefix = "include",
    includes = ["include"],

    # link options to be passed up to the dependencies of this library
    linkopts = select({
        "@platforms//os:android": [
            "-lOpenSLES",  # slCreateEngine, SL_IID_VOLUME, etc (OpenSL ES)
            "-lGLESv2",    # glActiveTexture, etc (GLES 2.0/3.0)
        ],
        "@bazel_tools//src/conditions:darwin": [
            "-framework", "CoreGraphics",
            "-framework", "CoreAudio",
            "-framework", "CoreHaptics",
            "-framework", "CoreMedia",
            "-framework", "CoreVideo",
            "-framework", "AVFoundation",
            "-framework", "AudioToolbox",
            "-framework", "ForceFeedback",
            "-framework", "GameController",
            "-framework", "IOKit",
            "-framework", "Carbon",
            "-framework", "Metal",
            "-framework", "AppKit",
            "-framework", "QuartzCore",
            "-framework", "UniformTypeIdentifiers",
        ],
        "@bazel_tools//src/conditions:windows": [
            "User32.lib",   # Window functions (CreateWindow, MessageBox, etc.)
            "Gdi32.lib",    # GDI functions (CreateDC, SelectObject, BitBlt, GetDeviceCaps, etc.)
            "Advapi32.lib", # Registry functions (RegOpenKeyExW, etc.)
            "Shell32.lib",  # Shell functions (ShellExecuteW, SHGetFolderPathW, etc.)
            "Ole32.lib",    # COM functions (CoInitializeEx, CoCreateInstance, etc.)
            "Oleaut32.lib", # OLE Automation functions (IDispatch, VARIANT, SysFreeString, etc.)
            "Imm32.lib",    # IME Input Method Manager functions
            "Winmm.lib",    # Windows Multimedia functions (timeBeginPeriod, etc.)
            "Version.lib",  # Version functions (GetFileVersionInfo, etc.)
            "Setupapi.lib", # Device Setup API functions (SetupDiGetClassDevs, etc.)
            #"Cfgmgr32.lib", # Configuration Manager functions
        ],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)

