# https://bazel-contrib.github.io/rules_foreign_cc/cmake.html
load("@bazel_skylib//rules:common_settings.bzl", "string_flag")
load("@rules_foreign_cc//foreign_cc:defs.bzl", "cmake")
load("@rules_cc//cc:defs.bzl", "cc_library")
load("@rules_cc//cc:objc_library.bzl", "objc_library")
load("@rules_android//rules:rules.bzl", "android_library")

string_flag(
    name = "build",
    build_setting_default = "via_cmake",
    values = [
        "via_cmake",
        "via_bazel",
    ],
    visibility = ["//visibility:public"],
)
config_setting(name = "via_cmake", flag_values = {":build": "via_cmake"})
config_setting(name = "via_bazel", flag_values = {":build": "via_bazel"})

################################
# Build via CMake foreign rule
################################
filegroup(
    name = "all_srcs",
    srcs = glob(["**"]),
    visibility = ["//visibility:private"],
)
filegroup(
    name = "all_android_java_srcs",
    srcs = glob(["android-project/app/src/main/java/org/libsdl/app/*.java"]),
    visibility = ["//visibility:public"],
)
filegroup(
    name = "android_default_manifest",
    srcs = ["android-project/app/src/main/AndroidManifest.xml"],
    visibility = ["//visibility:public"],
)

