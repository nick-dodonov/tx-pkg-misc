# if(SDL_JOYSTICK) && if(SDL_JOYSTICK_VIRTUAL)
VIRTUAL_JOYSTICK_SRCS = ["src/joystick/virtual/*.c"]

# if(SDL_VIDEO) && if(SDL_DUMMYVIDEO)
DUMMYVIDEO_SRCS = ["src/video/dummy/*.c"]

# if(APPLE)
#   if(SDL_CAMERA) && if(MACOS OR IOS)
APPLE_CAMERA_SRCS = ["src/camera/coremedia/*.m"]
#   !if(IOS OR TVOS OR VISIONOS OR WATCHOS)
DARWIN_MISC_SRCS = ["src/misc/macos/*.m"]
#   if(SDL_AUDIO)
APPLE_AUDIO_SRCS = ["src/audio/coreaudio/*.m"]
#   if(SDL_JOYSTICK)
APPLE_JOYSTICK_SRCS = ["src/joystick/apple/*.m"]
#   if(SDL_JOYSTICK) && !if(IOS OR TVOS OR VISIONOS OR WATCHOS)
DARWIN_JOYSTICK_SRCS = ["src/joystick/darwin/*.c"]
#   if(SDL_HAPTIC) && !if(IOS OR TVOS OR VISIONOS OR WATCHOS)
DARWIN_HAPTIC_SRCS = ["src/haptic/darwin/*.c"]
#   if(SDL_POWER) && !if(IOS OR TVOS OR VISIONOS OR WATCHOS)
DARWIN_POWER_SRCS = ["src/power/macos/*.c"]
#   General Apple platform sources
APPLE_GENERAL_SRCS = [
    "src/locale/macos/*.m",
    "src/time/unix/*.c",
    "src/timer/unix/*.c",
    "src/filesystem/cocoa/*.m",
    "src/storage/generic/*.c",
    "src/filesystem/posix/*.c",
]
#   if(SDL_SENSOR) && if(IOS OR VISIONOS OR WATCHOS)
COREMOTION_SENSOR_SRCS = ["src/sensor/coremotion/*.m"]
#   if(SDL_VULKAN OR SDL_METAL OR SDL_RENDER_METAL)
#       if(HAVE_FRAMEWORK_METAL) && if (SDL_GPU)
METAL_FRAMEWORK_SRCS = [
    "src/render/metal/*.m",
    "src/gpu/metal/*.m",
]
#   if(MACOS)
MACOS_TRAY_SRCS = ["src/tray/cocoa/*.m"]
#   if(SDL_COCOA)
COCOA_VIDEO_SRCS = ["src/video/cocoa/*.m"]

# if (SDL_DIALOG)
GENERAL_DIALOG_SRCS = ["src/dialog/*.c"]
#   if(MACOS)
MACOS_DIALOG_SRCS = ["src/dialog/cocoa/*.m"]

GENERAL_PROCESS_SRCS = ["src/process/*.c"]
POSIX_PROCESS_SRCS = ["src/process/posix/*.c"]

# if(SDL_PTHREADS)
PTHREAD_THREAD_SRCS = ["src/thread/pthread/*.c"]

# if(SDL_VIDEO) && if(SDL_OFFSCREEN)
GENERAL_OFFSCREEN_SRCS = ["src/video/offscreen/*.c"]

GENERAL_TRAY_SRCS = ["src/tray/*.c"]

DUMMY_SENSOR_SRCS = ["src/sensor/dummy/*.c"]

HIDAPI_JOYSTICK_SRCS = ["src/joystick/hidapi/*.c"]

VULKAN_GPU_SRCS = ["src/gpu/vulkan/*.c"]

HIDAPI_HAPTIC_SRCS = ["src/haptic/hidapi/*.c"]

objc_library(
    name = "sdl3_darwin",
    srcs = glob(
        GENERAL_SRCS
        + GENERAL_MAIN_SRCS
        + DUMMYAUDIO_SRCS
        + DISKAUDIO_SRCS
        + DUMMYCAMERA_SRCS
        + VIRTUAL_JOYSTICK_SRCS
        + DUMMYVIDEO_SRCS

        + DLOPEN_SRCS
        + APPLE_CAMERA_SRCS
        + DARWIN_MISC_SRCS
        + APPLE_AUDIO_SRCS
        + APPLE_JOYSTICK_SRCS
        + DARWIN_JOYSTICK_SRCS
        + DARWIN_HAPTIC_SRCS
        + DARWIN_POWER_SRCS
        + APPLE_GENERAL_SRCS
        + METAL_FRAMEWORK_SRCS
        + GENERAL_TRAY_SRCS
        + MACOS_TRAY_SRCS
        + COCOA_VIDEO_SRCS
        + COREMOTION_SENSOR_SRCS
        + HIDAPI_JOYSTICK_SRCS

        + GENERAL_DIALOG_SRCS
        + MACOS_DIALOG_SRCS
        + GENERAL_PROCESS_SRCS
        + POSIX_PROCESS_SRCS
        + PTHREAD_THREAD_SRCS
        + GENERAL_OFFSCREEN_SRCS
        + DUMMY_SENSOR_SRCS
        + VULKAN_GPU_SRCS

        + HIDAPI_HAPTIC_SRCS
    ),
    hdrs = glob(["include/**/*.h"]),
    copts = [
        # lot of warning: '<name>' is deprecated: first deprecated in macOS 13.0 - Use MTLGPUFamily instead [-Wdeprecated-declarations]
        "-Wno-deprecated-declarations",
        # SDL_tray.m:379:98: warning: undeclared selector 'menu:' [-Wundeclared-selector]
        "-Wno-undeclared-selector",
    ],
    includes = [
        "src",
        "include",
        "include/build_config",
        "src/video/khronos",
    ],
    linkopts = [
        "-framework", "CoreGraphics",
        "-framework", "CoreAudio",
        "-framework", "CoreHaptics",
        "-framework", "CoreMedia",
        "-framework", "CoreVideo",
        "-framework", "AVFoundation",
        "-framework", "AudioToolbox",
        "-framework", "ForceFeedback",
        "-framework", "GameController",
        "-framework", "IOKit",
        "-framework", "Carbon",
        "-framework", "Metal",
        "-framework", "AppKit",
        "-framework", "QuartzCore",
        "-framework", "UniformTypeIdentifiers",
    ],
    visibility = ["//visibility:private"],
)

cc_library(
    name = "sdl3_wasm",
    srcs = glob(
        GENERAL_SRCS
        + DUMMYAUDIO_SRCS
