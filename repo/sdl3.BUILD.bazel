    "src/misc/*.c",
    "src/power/*.c",
    "src/render/*.c",
    "src/render/*/*.c",
    "src/sensor/*.c",
    "src/stdlib/*.c",
    "src/storage/*.c",
    "src/thread/*.c",
    "src/time/*.c",
    "src/timer/*.c",
