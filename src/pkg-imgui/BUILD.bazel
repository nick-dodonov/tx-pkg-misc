load("@tx-kit-ext//rules/build:multi_lib.bzl", "multi_lib")

multi_lib(
    name = "pkg-imgui",
    srcs = glob(["**/*.cpp"]),
    hdrs = glob(["**/*.h"]),
    strip_include_prefix = ".",
    data = [
        "//data:fonts_dir",
    ],
    deps = [
        "//src/pkg-sdl",
        "@tx-pkg-aux//src/pkg-fs",
        "@imgui//:imgui",
        "@imgui//backends:platform-sdl3",
        "@imgui//backends:renderer-sdlrenderer3",  #TODO: try SDL_GPU renderer as more modern and advanced
    ],
    linkopts = select({
        "//conditions:default": [],
        "@platforms//cpu:wasm32": [
            "--preload-file", "$(rootpath //data:fonts_dir)@/data/fonts",
        ],
    }),
    visibility = ["//visibility:public"],
)
